{
  "compilerOptions": {
    "target": "es2024",
    "paths": {
      "components/*": [
        "./components/*"
      ],
      "pages/*": [
        "./pages/*"
      ],
      "lib/*": [
        "./lib/*"
      ],
      "styles/*": [
        "./styles/*"
      ],
      "public/*": [
        "./public/*"
      ],
      "leaflet/*": [
        "./node_modules/leaflet/dist/*"
      ],
      "leaflet-draw/*": [
        "./node_modules/leaflet-draw/dist/*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "moduleResolution": "node"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "_*"
  ]
}
